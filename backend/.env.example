# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# BCC OAuth2 Client Credentials (for API access)
BCC_OAUTH_CLIENT_ID=your-client-id
BCC_OAUTH_CLIENT_SECRET=your-client-secret

# BCC OpenID Connect (for user authentication)
BCC_OIDC_CLIENT_ID=your-oidc-client-id
BCC_OIDC_CLIENT_SECRET=your-oidc-client-secret

# Flask Session Secret (generate with: python -c "import os; print(os.urandom(24).hex())")
FLASK_SECRET_KEY=your-secret-key-here

# Optional: Multi-tenant filtering
# TENANT_ID=your-tenant-id

# Optional: Demo mode (serves static JSON responses, no credentials required)
# DEMO_MODE=1
